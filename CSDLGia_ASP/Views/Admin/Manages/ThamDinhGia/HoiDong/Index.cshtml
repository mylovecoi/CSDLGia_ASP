@{
    int record_id = 1;
}
@model IEnumerable<CSDLGia_ASP.Models.Manages.ThamDinhGia.ThamDinhGiaHD>

@section custom_style {
    <link rel="stylesheet" type="text/css" href="~/Admin/assets/datatables/bootstrap/dataTables.bootstrap.css" />
    <link rel="stylesheet" type="text/css" href="~/Admin/assets/datatables/bootstrap/dataTables.css" />
}

@section custom_script {
    <script type="text/javascript" src="~/Admin/assets/datatables/js/jquery.dataTables.min.js"></script>
    <script type="text/javascript" src="~/Admin/assets/datatables/bootstrap/dataTables.bootstrap.js"></script>
    <script src="~/Admin/assets/datatables/scripts/table-managed.js"></script>
    <script src="~/Admin/assets/js/pages/crud/forms/widgets/select2.js"></script>
    <script>
        $(document).ready(function() {
            TableManaged.init();
            TableManaged2.init();
            $('.select2multi').select2();
        });
    </script>
}

<div class="card card-custom">
    <div class="card-header flex-wrap border-0 pt-6 pb-0">
        <div class="card-title">
            <h3 class="card-label">
                Thông tin hội đồng thẩm định
            </h3>
        </div>
        <div class="card-toolbar">
            @if (Helpers.CheckPermission(HttpContextAccessor.HttpContext.Session, "csdltdg.tdg.hd", "Create"))
            {
                <a class="btn btn-primary font-weight-bolder" asp-controller="ThamDinhGiaHD" asp-action="CreateOrEdit">
                    <i class="la la-plus"></i>Thêm mới
                </a>
            }
        </div>
    </div>
    <hr />
    <div class="card-body">
        <table class="table table-striped table-bordered table-hover" id="sample_3">
            <thead>
                <tr style="text-align:center">
                    <th width="4%">#</th>
                    <th>Tên hội đồng</th>
                    <th>Căn cứ pháp lý</th>
                    <th>Theo đề nghị</th>
                    <th>Số quyết định</th>
                    <th>Ngày quyết định</th>
                    <th>Nội dung quyết định</th>
                    <th width="20%">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="text-align: center">@(record_id++)</td>
                            <td>@item.TenHoiDong</td>
                            <td>@item.CanCuPhapLy</td>
                            <td>@item.TheoDeNghi</td>
                            <td>@item.SoQD</td>
                            <td style="text-align: center">@Helpers.ConvertDateToStr(item.NgayQD)</td>
                            <td>@item.NoiDungQD</td>
                            <td>
                                <a asp-controller="ThamDinhGiaHD" asp-action="Show" asp-route-MaHoiDong="@item.MaHoiDong" class="btn btn-sm btn-clean btn-icon" title="Xem chi tiết"
                                       target="_blank">
                                    <i class="icon-lg la la-eye text-success"></i>
                                </a>
                                @if (Helpers.CheckPermission(HttpContextAccessor.HttpContext.Session, "csdltdg.tdg.hd", "Edit"))
                                {
                                    <a asp-controller="ThamDinhGiaHD" asp-action="CreateOrEdit" asp-route-MaHoiDong="@item.MaHoiDong" class="btn btn-sm btn-clean btn-icon" title="Chỉnh sửa">
                                        <i class="icon-lg la la-edit text-primary"></i>
                                    </a>
                                }
                                @if (Helpers.CheckPermission(HttpContextAccessor.HttpContext.Session, "csdltdg.tdg.hd", "Delete"))
                                {
                                    <button type="button" class="btn btn-sm btn-clean btn-icon" title="Xóa" data-toggle="modal" data-target="#Delete_Modal" onclick="SetDelete('@item.Id')">
                                        <i class="icon-lg la la-trash text-danger"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!--Delete Modal-->
<div class="modal fade" id="Delete_Modal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form asp-controller="ThamDinhGiaHD" asp-action="Delete">
                <div class="modal-header">
                    <h3 class="card-label">
                        Đồng ý xóa thông tin hội đồng thẩm định???
                    </h3>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <i aria-hidden="true" class="ki ki-close"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <input id="id_delete" name="id_delete" type="hidden" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light-primary font-weight-bold" data-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-danger font-weight-bold">Xóa</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function SetDelete(id) {
        document.getElementById("id_delete").value = id;
    }
</script>