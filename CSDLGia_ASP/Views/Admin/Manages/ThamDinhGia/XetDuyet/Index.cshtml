@{
    int record_id = 1;
    int Nam = ViewData["Nam"] as int? ?? 0;
}
@model IEnumerable<CSDLGia_ASP.Models.Manages.ThamDinhGia.ThamDinhGia>

@section custom_style {
    <link rel="stylesheet" type="text/css" href="~/Admin/assets/datatables/bootstrap/dataTables.bootstrap.css" />
    <link rel="stylesheet" type="text/css" href="~/Admin/assets/datatables/bootstrap/dataTables.css" />
}

@section custom_script {
    <script type="text/javascript" src="~/Admin/assets/datatables/js/jquery.dataTables.min.js"></script>
    <script type="text/javascript" src="~/Admin/assets/datatables/bootstrap/dataTables.bootstrap.js"></script>
    <script src="~/Admin/assets/datatables/scripts/table-managed.js"></script>
    <script src="~/Admin/assets/js/pages/crud/forms/widgets/select2.js"></script>
    <script>
        $(document).ready(function () {
            TableManaged.init();
        });

        $(function () {
            $('#Madv, #Nam').change(function () {
                var current_path_url = '/ThamDinhGia/XetDuyet?';
                var madv = '&Madv=' + $('#Madv').val();
                var nam = '&Nam=' + $('#Nam').val();
                var url = current_path_url + madv + nam;
                window.location.href = url;
            })
        });
    </script>
}

<div class="card card-custom">
    <div class="card-header flex-wrap border-0 pt-6 pb-0">
        <div class="card-title">
            <h3 class="card-label">
                Hồ sơ thẩm định giá
            </h3>
        </div>
        <div class="card-toolbar">
        </div>
    </div>
    <hr />
    <div class="card-body">
        <div class="row">
            <div class="col-xl-3">
                <div class="form-group fv-plugins-icon-container">
                    <label style="font-weight:bold; color:blue">Năm</label>
                    <select class="form-control select2basic" id="Nam" name="Nam">
                        <option value="0">--Tất cả--</option>
                        @{
                            int nam_start = DateTime.Now.Year - 5;
                            int nam_stop = DateTime.Now.Year + 1;
                            for (int i = nam_start; i <= nam_stop; i++)
                            {
                                <!option value="@i" @(Nam == i ? "selected" : "")>Năm @i</!option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
        <table class="table table-striped table-bordered table-hover" id="sample_3">
            <thead>
                <tr style="text-align:center">
                    <th width="4%">#</th>
                    <th>Cơ quan chuyển hồ sơ</th>
                    <th>Thời điểm xác định</th>
                    <th>Thông tin tài sản thẩm định</th>
                    <th>Đơn vị yêu cầu thẩm định</th>
                    <th>Thông tin hồ sơ</th>
                    <th>Trạng thái</th>
                    <th>Trạng thái CSDL<br /> Giá Quốc Gia</th>
                    <th>Cơ quan tiếp nhận hồ sơ</th>
                    <th width="15%">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="text-align: center">@(record_id++)</td>
                            <td class="active">@item.TendvCh</td>
                            <td style="text-align: center">@Helpers.ConvertDateToStr(item.Thoidiem)</td>
                            <td>@item.Tttstd</td>
                            <td>@item.Dvyeucau</td>
                            <td>@item.Ghichu</td>
                            <td style="text-align: center">
                                @if (item.Trangthai == "CD")
                                {
                                    <span class="label font-weight-bold label-lg label-inline label-light-warning">Chờ duyệt</span>
                                }
                                else if (item.Trangthai == "DD")
                                {
                                    <span class="label font-weight-bold label-lg label-inline label-light-primary">Đã duyệt</span>
                                }
                                else if (item.Trangthai == "BTL")
                                {
                                    <span class="label font-weight-bold label-lg label-inline label-light-danger">Bị trả lại</span>
                                    <p>Lý do:&nbsp;@item.Lydo</p>
                                }
                                else
                                {
                                    <span class="label font-weight-bold label-lg label-inline label-light-success">Công bố</span>
                                }
                            </td>
                            <td style="text-align: center">
                                @if (item.TrangThaiCSDLQG == "" || item.TrangThaiCSDLQG == null)
                                {
                                    <span class="label font-weight-bold label-lg  label-outline-warning label-inline">Chưa kết nối</span>
                                }
                                @if (item.TrangThaiCSDLQG == "DAKETNOI")
                                {
                                    <span class="label font-weight-bold label-lg  label-light-info label-inline">Đã kết nối</span>
                                }
                            </td>
                            <td style="text-align: left">@item.Tencqcq</td>
                            <td>
                                <a asp-controller="ThamDinhGia" asp-action="Show" asp-route-Mahs="@item.Mahs" class="btn btn-sm btn-clean btn-icon" title="Xem chi tiết"
                                   target="_blank">
                                    <i class="icon-lg la la-eye text-success"></i>
                                </a>
                                <button type="button" onclick="GetFile('@item.Mahs')" class="btn btn-sm btn-clean btn-icon" title="Giấy tờ kèm theo">
                                    <i class="icon-lg la la-file-alt text-dark"></i>
                                </button>
                                @if (item.Trangthai == "CD")
                                {
                                    @if (Helpers.CheckPermission(HttpContextAccessor.HttpContext.Session, "csdltdg.tdg.xd", "Approve"))
                                    {
                                        <button type="submit" class="btn btn-sm btn-clean btn-icon" title="Trả lại" data-toggle="modal" data-target="#TraLai_Modal"
                                                onclick="TraLai('@item.Id')">
                                            <i class="icon-lg la la-reply text-danger "></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-clean btn-icon" title="Duyệt" data-toggle="modal" data-target="#Duyet_Modal" onclick="SetDuyet('@item.Mahs', '@item.Sotbkl')">
                                            <i class="icon-lg la la-check text-primary"></i>
                                        </button>
                                    }
                                }
                                @if (item.Trangthai == "DD")
                                {
                                    @if (Helpers.CheckPermission(HttpContextAccessor.HttpContext.Session, "csdltdg.tdg.xd", "Approve"))
                                    {
                                        <button type="button" class="btn btn-sm btn-clean btn-icon" title="Hủy duyệt" data-toggle="modal" data-target="#HuyDuyet_Modal"
                                                onclick="SetHuyDuyet('@item.Mahs','@item.Sotbkl')">
                                            <i class="icon-lg la la-times text-danger "></i>
                                        </button>
                                    }
                                    @if (Helpers.CheckPermission(HttpContextAccessor.HttpContext.Session, "csdltdg.tdg.xd", "Approve"))
                                    {
                                        <button type="button" class="btn btn-sm btn-clean btn-icon" title="Công bố" data-toggle="modal" data-target="#CongBo_Modal"
                                                onclick="CongBo('@item.Mahs','@item.Sotbkl')">
                                            <i class="icon-lg la la-send text-primary "></i>
                                        </button>
                                    }
                                }
                                @if (item.Trangthai == "CB")
                                {
                                    @if (Helpers.CheckPermission(HttpContextAccessor.HttpContext.Session, "csdltdg.tdg.xd", "Approve"))
                                    {
                                        <button type="button" class="btn btn-sm btn-clean btn-icon" title="Hủy công bố" data-toggle="modal" data-target="#HuyCongBo_Modal"
                                                onclick="HuyCongBo('@item.Mahs', '@item.Sotbkl')">
                                            <i class="icon-lg la la-times text-danger "></i>
                                        </button>
                                    }
                                }
                                @{
                                    ViewData["maHoSoTruyen"] = item.Mahs;
                                }
                                @await Html.PartialAsync("~/Views/Admin/_DungChung/KetNoiAPI/Index_button.cshtml", ViewData["maHoSoTruyen"])
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
@await Html.PartialAsync("~/Views/Admin/Manages/ThamDinhGia/XetDuyet/Modal.cshtml")
@await Html.PartialAsync("~/Views/Admin/_DungChung/KetNoiAPI/Index_modal.cshtml")
